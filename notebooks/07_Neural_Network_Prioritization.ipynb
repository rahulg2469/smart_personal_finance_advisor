    {
      "cell_type": "code",
      "source": [
        "def calculate_priority_scores(row):\n",
        "    \"\"\"\n",
        "    Calculate priority scores based on user behavior patterns\n",
        "    Higher score = should cut this category first\n",
        "    \"\"\"\n",
        "    scores = {}\n",
        "\n",
        "    for category in user_category_pct.columns:\n",
        "        pct = row[category]\n",
        "        if pct > 30:\n",
        "            base_score = 3.0  # Hard to cut\n",
        "        elif pct > 20:\n",
        "            base_score = 5.0  # Medium difficulty\n",
        "        elif pct > 10:\n",
        "            base_score = 7.0  # Easier to cut\n",
        "        else:\n",
        "            base_score = 9.0  # Easy to cut\n",
        "\n",
        "        if row['coefficient_of_variation'] > 1.5:\n",
        "            base_score += 1.0\n",
        "\n",
        "        if row['weekend_pct'] < 0.2:\n",
        "            base_score -= 0.5\n",
        "\n",
        "        scores[category] = np.clip(base_score, 0, 10)\n",
        "\n",
        "    return pd.Series(scores)\n",
        "\n",
        "priority_labels = ml_features.apply(calculate_priority_scores, axis=1)\n",
        "\n",
        "print(f\" Created priority labels for {len(priority_labels)} users\")\n",
        "print(f\"  Score range: 0-10 (higher = should cut first)\")\n",
        "print(\"\\nSample priority scores:\")\n",
        "display(priority_labels.head())"
      ],
