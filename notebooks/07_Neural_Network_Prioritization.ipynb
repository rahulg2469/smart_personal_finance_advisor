    {
      "cell_type": "markdown",
      "source": [
        "Creating User level Features"
      ],
      "metadata": {
        "id": "_K-GSDAqD_DK"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "df = pd.read_csv('/content/drive/MyDrive/archive/fraudTrain_cleaned.csv')\n",
        "\n",
        "print(f\"\\n Loaded {len(df):,} transactions\")\n",
        "df['datetime'] = pd.to_datetime(df['datetime'])\n",
        "user_features = df.groupby('cc_num').agg({\n",
        "    'amt': ['count', 'sum', 'mean', 'std', 'min', 'max'],\n",
        "    'is_weekend': 'mean',\n",
        "    'hour': 'mean',\n",
        "    'day_of_week': 'mean'\n",
        "}).round(2)\n",
        "\n",
        "user_features.columns = ['_'.join(col).strip() for col in user_features.columns.values]\n",
        "user_features.columns = [\n",
        "    'total_transactions',\n",
        "    'total_spending',\n",
        "    'avg_transaction',\n",
        "    'std_transaction',\n",
        "    'min_transaction',\n",
        "    'max_transaction',\n",
        "    'weekend_pct',\n",
        "    'avg_hour',\n",
        "    'avg_day_of_week'\n",
        "]\n",
        "\n",
        "# some additional features\n",
        "user_features['spending_range'] = user_features['max_transaction'] - user_features['min_transaction']\n",
        "user_features['coefficient_of_variation'] = (user_features['std_transaction'] / user_features['avg_transaction']).fillna(0)\n",
        "\n",
        "print(f\" Created {len(user_features.columns)} behavioral features for {len(user_features)} users\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "JH2oovSJD8G1",
        "outputId": "f632d4d7-6959-43a6-d0b6-6a95b532774b"
      },
      "execution_count": 3,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "\n",
            " Loaded 1,296,675 transactions\n",
            " Created 11 behavioral features for 983 users\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "user_category = df.groupby(['cc_num', 'category'])['amt'].sum().unstack(fill_value=0)\n",
        "user_total = user_category.sum(axis=1)\n",
        "user_category_pct = user_category.div(user_total, axis=0) * 100\n",
        "\n",
        "print(f\" Created category spending percentages\")\n",
        "print(f\" Categories: {list(user_category_pct.columns)}\")\n",
        "ml_features = user_features.merge(user_category_pct, left_index=True, right_index=True, how='inner')\n",
        "\n",
        "print(f\"\\n Final feature matrix: {ml_features.shape[0]} users × {ml_features.shape[1]} features\")\n",
        "display(ml_features.head())"
      ],
